        "jsCode": "const topic = $('Set Topic').first().json.topic;\n\nconst keywordMap = {\n  경제: [\"경제\",\"주식\",\"증시\",\"금리\",\"환율\",\"투자\",\"부동산\"],\n  IT: [\"AI\",\"반도체\",\"로봇\",\"배터리\",\"클라우드\",\"데이터센터\"],\n  국제: [\"미국\",\"중국\",\"일본\",\"유럽\",\"중동\",\"러시아\"],\n  정치: [\"대통령\",\"국회\",\"정부\",\"선거\"],\n  생활: [\"교육\",\"복지\",\"교통\",\"의료\",\"물가\"]\n};\n\nconst keywords = keywordMap[topic] || [];\n\nreturn items.filter(item => {\n  const text =\n    (item.json.title || \"\") +\n    \" \" +\n    (item.json.description || \"\");\n\n  return keywords.some(k => text.includes(k));\n});"
