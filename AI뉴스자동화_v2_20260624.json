      "parameters": {
        "jsCode": "const allPreviousItems = $('Topic Filter').all();\n\nreturn items.map(item => {\n  const link = item.json.link || \"\";\n  const original = allPreviousItems.find(prev => prev.json.link === link);\n\n  return {\n    json: {\n      title: item.json.title || \"\",\n      link,\n      source: item.json.source || original?.json.source || \"\",\n      publishedAt:\n        item.json.publishedAt ||\n        original?.json.publishedAt ||\n        original?.json.pubDate ||\n        \"\",\n      summary:\n        item.json.summary ||\n        item.json.output?.[0]?.content?.[0]?.text ||\n        item.json.content?.[0]?.text ||\n        \"\",\n      dedupeKey: link\n    }\n  };\n});"
