    {
      "parameters": {
        "jsCode": "if (items.length === 0) return [];\n\nfunction normalizeTitle(title) {\n  return String(title || \"\")\n    .replace(/\\[[^\\]]*\\]/g, \"\")\n    .replace(/[^\\w가-힣\\s]/g, \"\")\n    .replace(/\\s+/g, \" \")\n    .trim()\n    .slice(0, 35);\n}\n\nconst seenLinks = new Set();\nconst seenTitles = new Set();\nconst unique = [];\n\nfor (const item of items) {\n  const link = item.json.link || \"\";\n  const titleKey = normalizeTitle(item.json.title);\n\n  if (!link || !titleKey) continue;\n  if (seenLinks.has(link)) continue;\n  if (seenTitles.has(titleKey)) continue;\n\n  seenLinks.add(link);\n  seenTitles.add(titleKey);\n  unique.push(item);\n}\n\nconst groups = {};\n\nfor (const item of unique) {\n  const source = item.json.source || \"unknown\";\n  if (!groups[source]) groups[source] = [];\n  groups[source].push(item);\n}\n\nconst sources = Object.keys(groups);\nconst mixed = [];\nconst maxLen = Math.max(...sources.map(source => groups[source].length));\n\nfor (let i = 0; i < maxLen; i++) {\n  for (const source of sources) {\n    if (groups[source][i]) {\n      mixed.push(groups[source][i]);\n    }\n  }\n}\n\nreturn mixed.slice(0, 80);"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -1152,
