    {
      "parameters": {
        "jsCode": "const copyrightPatterns = [\n  \"무단전재\", \"재배포 금지\", \"무단 복제\", \"무단복제\",\n  \"저작권자\", \"무단 전재\", \"기사 원문의 저작권\",\n  \"무단전재 및 재배포\", \"저작권법에 의해\"\n];\n\nreturn items.map(item => {\n  const html = String(item.json.data || item.json.body || \"\").toLowerCase();\n  const hasCopyright = copyrightPatterns.some(p => html.includes(p));\n\n  const prev = $('Parse Top 3').all();\n  const link = item.json.link || \"\";\n  const original = prev.find(o => o.json.link === link) || {};\n\n  return {\n    json: {\n      title: original.json?.title || item.json.title || \"\",\n      link: link,\n      source: original.json?.source || item.json.source || \"\",\n      publishedAt: original.json?.publishedAt || item.json.publishedAt || \"\",\n      reason: original.json?.reason || item.json.reason || \"\",\n      hasCopyright: hasCopyright\n    }\n  };\n});"
      },
